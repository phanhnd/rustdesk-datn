# Copy file này thành .env và điền giá trị thật
# Khi đổi mạng/IP: chỉ cần sửa VM_HOST rồi restart node server.js

# Địa chỉ gateway (host:port) — cũng dùng làm REDIRECT_URI cho Keycloak
VM_HOST=localhost:3000

# Địa chỉ Keycloak server
KEYCLOAK_HOST=localhost:8080

# Keycloak realm và client cho RustDesk desktop app
REALM=rustdesk
CLIENT_ID=rustdesk-client
CLIENT_SECRET=

# Keycloak client cho Admin UI
ADMIN_CLIENT_ID=rocky-admin
ADMIN_CLIENT_SECRET=

# SQLite database file
DB_FILE=./data/rocky.db

# Thời gian session admin (ms), mặc định 8 giờ
ADMIN_SESSION_TTL_MS=28800000
